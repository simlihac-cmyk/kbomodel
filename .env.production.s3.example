ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=scrypt:replace-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

KBO_TIMEZONE=Asia/Seoul
OFFICIAL_KBO_ONLY=true
ENABLE_STATIZ_ENRICHMENT=false
HOT_POLLER_ENABLED=true
FULL_SIM_ON_FINAL_ONLY=true

INGEST_PUBLISH_MODE=blob-plan
INGEST_PUBLISH_SECRET=replace-with-internal-shared-secret
INGEST_BLOB_PLAN_URL=https://your-app.example.com/api/internal/ingest/blob-plan
INGEST_BLOB_PLAN_SECRET=replace-with-internal-shared-secret

# AWS S3 presign signer
INGEST_S3_ACCESS_KEY_ID=replace-with-iam-access-key-id
INGEST_S3_SECRET_ACCESS_KEY=replace-with-iam-secret-access-key
INGEST_S3_REGION=ap-northeast-2
INGEST_S3_BUCKET=kbo-live
INGEST_S3_ENDPOINT=https://s3.ap-northeast-2.amazonaws.com
INGEST_S3_PUBLIC_BASE_URL=https://cdn.example.com/kbo-live
INGEST_S3_FORCE_PATH_STYLE=false
INGEST_S3_PRESIGN_EXPIRES_IN=900

INGEST_USER_AGENT=kbo-race-lab/1.0 (+ops)
FETCH_MAX_RETRIES=3
FETCH_RETRY_BACKOFF_MS=750
FETCH_POLITENESS_MS=250
WRITE_RAW_SNAPSHOTS=true
